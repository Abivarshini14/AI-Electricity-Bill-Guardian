# Security
SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./electricity_guardian.db

# Grok / xAI
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-2-latest

# Optional
WEATHER_API_KEY=

# SMTP (leave blank to disable email sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Frontend
FRONTEND_URL=http://localhost:5173

ENVIRONMENT=development

# Demo admin (development only - do not use in production)
DEMO_ADMIN_EMAIL=admin@guardianapp.com
DEMO_ADMIN_PASSWORD=Admin@12345
DEMO_ADMIN_NAME=System Admin
